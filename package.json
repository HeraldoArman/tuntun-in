{
  "name": "tuntun-in",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "type": "module",
  "scripts": {
    "dev": "nx run-many -t dev",
    "build": "nx run-many -t build",
    "check-types": "nx run-many -t check-types",
    "dev:web": "nx run-many -t dev --projects=web",
    "dev:server": "nx run-many -t dev --projects=@tuntun-in/backend",
    "dev:setup": "nx run-many -t dev:setup --projects=@tuntun-in/backend",
    "dev:agent": "nx run agent:dev",
    "check:agent": "nx run agent:check",
    "docker:build": "docker compose build",
    "docker:up": "docker compose up -d --build",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f",
    "check": "ultracite check",
    "fix": "ultracite fix"
  },
  "dependencies": {
    "@tuntun-in/env": "workspace:*",
    "dotenv": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.16",
    "@tuntun-in/config": "workspace:*",
    "nx": "^22.7.5",
    "typescript": "catalog:",
    "ultracite": "7.8.3"
  },
  "packageManager": "pnpm@11.10.0"
}
