# LiveKit — get from livekit.io/cloud
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=your_api_key
LIVEKIT_API_SECRET=your_api_secret

# Google AI — get from aistudio.google.com
GOOGLE_API_KEY=your_gemini_api_key

# Google Maps — get from console.cloud.google.com (enable Geocoding + Directions APIs)
# Used by Deep Navigator for macro-to-micro navigation. Optional: if unset, the
# navigate_to tool degrades gracefully and tells the user maps are unavailable.
GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# Convex — get from dashboard.convex.dev
CONVEX_URL=https://your-project.convex.cloud
CONVEX_SERVICE_SECRET=your_service_secret

# Public web URL — where the spectator page lives (no trailing slash).
# Used by Overwatch to build the guardian's live-view link.
PUBLIC_WEB_URL=https://example.com

# Overwatch WhatsApp delivery via GoWA (go-whatsapp-web-multidevice REST API).
# GOWA_BASE_URL: the GoWA service URL (e.g. http://localhost:8080 locally, or
#   the Railway private domain of the gowa service in production).
# GOWA_DEVICE_ID: the logged-in WhatsApp device JID (e.g. 6281234567890@s.whatsapp.net).
# Optional basic auth, if the GoWA instance is secured:
#   GOWA_USERNAME / GOWA_PASSWORD
GOWA_BASE_URL=http://localhost:8080
GOWA_DEVICE_ID=your-device-id@s.whatsapp.net
